#!/usr/bin/env bash
# Pre-push hook: runs validation checks in parallel.
# 1. Block pushes when GitHub Actions is degraded
# 2. Validate CI workflows and Dockerfiles match repo structure

set -uo pipefail

PIDS=()
NAMES=()
FAILS=0

run_check() {
  local name="$1"
  shift
  "$@" &
  PIDS+=($!)
  NAMES+=("$name")
}

run_check "github-actions-status" bash ci/hooks/check-actions-status.sh
run_check "validate-ci" bash ci/hooks/validate-ci.sh

for i in "${!PIDS[@]}"; do
  if ! wait "${PIDS[$i]}"; then
    echo "FAIL: ${NAMES[$i]}" >&2
    FAILS=$((FAILS + 1))
  fi
done

if [ "$FAILS" -gt 0 ]; then
  exit 1
fi
