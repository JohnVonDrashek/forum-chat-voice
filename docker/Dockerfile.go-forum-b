# ---- Go build stage ----
FROM golang:1.26-alpine AS go-build

WORKDIR /app
COPY example-forum-instances-and-shared-forum-server/go.mod example-forum-instances-and-shared-forum-server/go.sum ./
COPY shared-go/ /shared-go/
COPY forum-server/forum/ /forum-server/forum/
COPY forum-server/go.mod /forum-server/go.mod
RUN go mod download

COPY example-forum-instances-and-shared-forum-server/platform/ platform/
COPY example-forum-instances-and-shared-forum-server/forum-b/main.go forum-b/main.go
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/bin/forum ./forum-b/

# ---- Frontend build stage ----
FROM node:20-slim AS frontend-build

RUN corepack enable && corepack prepare pnpm@10.6.5 --activate

WORKDIR /app

COPY example-forum-instances-and-shared-forum-server/forum-b/package.json example-forum-instances-and-shared-forum-server/forum-b/pnpm-lock.yaml* ./

# Install dependencies
RUN pnpm install --frozen-lockfile || pnpm install

# Copy source and build
COPY example-forum-instances-and-shared-forum-server/forum-b/ .
RUN pnpm run build

# ---- Production stage ----
FROM alpine:3.21

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=go-build /app/bin/forum .
COPY --from=frontend-build /app/dist ./dist/

ENV PORT=3000
EXPOSE 3000

CMD ["./forum"]
